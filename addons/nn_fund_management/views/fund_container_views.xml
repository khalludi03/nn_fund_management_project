<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List View ── -->
    <record id="view_fund_container_list" model="ir.ui.view">
        <field name="name">nn.fund.container.list</field>
        <field name="model">nn.fund.container</field>
        <field name="arch" type="xml">
            <tree>
                <field name="code"/>
                <field name="name"/>
                <field name="container_type"
                       widget="badge"
                       decoration-info="container_type=='project'"
                       decoration-warning="container_type=='expense_head'"/>
                <field name="total_allocated"/>
                <field name="available_balance"/>
                <field name="requisition_hold"/>
                <field name="transfer_hold"/>
                <field name="total_spent"/>
                <field name="currency_id" invisible="1"/>
                <field name="company_id"/>
            </tree>
        </field>
    </record>

    <!-- ── Form View ── -->
    <record id="view_fund_container_form" model="ir.ui.view">
        <field name="name">nn.fund.container.form</field>
        <field name="model">nn.fund.container</field>
        <field name="arch" type="xml">
            <form string="Project / Expense Head">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Basic Info">
                            <field name="code"/>
                            <field name="container_type"/>
                            <field name="currency_id"/>
                            <field name="company_id"/>
                            <field name="active"/>
                        </group>
                        <group string="Description">
                            <field name="description" nolabel="1"/>
                        </group>
                    </group>

                    <!-- Balance Dashboard -->
                    <group string="Balance Summary">
                        <group>
                            <field name="total_allocated"
                                   readonly="1"/>
                            <field name="incoming_transfer"
                                   readonly="1"/>
                            <field name="outgoing_transfer"
                                   readonly="1"/>
                        </group>
                        <group>
                            <field name="requisition_hold"
                                   readonly="1"/>
                            <field name="transfer_hold"
                                   readonly="1"/>
                            <field name="total_spent"
                                   readonly="1"/>
                        </group>
                        <group>
                            <field name="available_balance"
                                   readonly="1"
                                   widget="monetary"/>
                        </group>
                    </group>

                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ── Action: All ── -->
    <record id="action_fund_container" model="ir.actions.act_window">
        <field name="name">Projects / Expense Heads</field>
        <field name="res_model">nn.fund.container</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- ── Action: Projects only ── -->
    <record id="action_fund_project" model="ir.actions.act_window">
        <field name="name">Projects</field>
        <field name="res_model">nn.fund.container</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('container_type', '=', 'project')]</field>
        <field name="context">
            {'default_container_type': 'project'}
        </field>
    </record>

    <!-- ── Action: Expense Heads only ── -->
    <record id="action_fund_expense_head" model="ir.actions.act_window">
        <field name="name">Expense Heads</field>
        <field name="res_model">nn.fund.container</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">
            [('container_type', '=', 'expense_head')]
        </field>
        <field name="context">
            {'default_container_type': 'expense_head'}
        </field>
    </record>

    <!-- ── Menus ── -->
    <menuitem
        id="menu_fund_container_root"
        name="Configuration"
        parent="menu_fund_management_root"
        sequence="90"/>

    <menuitem
        id="menu_fund_project"
        name="Projects"
        parent="menu_fund_container_root"
        action="action_fund_project"
        sequence="10"/>

    <menuitem
        id="menu_fund_expense_head"
        name="Expense Heads"
        parent="menu_fund_container_root"
        action="action_fund_expense_head"
        sequence="20"/>

</odoo>