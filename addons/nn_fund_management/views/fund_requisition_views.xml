<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fund_requisition_list" model="ir.ui.view">
        <field name="name">nn.fund.requisition.list</field>
        <field name="model">nn.fund.requisition</field>
        <field name="arch" type="xml">
            <tree string="Fund Requisitions"
                  decoration-success="state=='approved'"
                  decoration-warning="state in ('submitted','gm_approved')"
                  decoration-danger="state in ('rejected','cancelled')"
                  decoration-muted="state=='closed'">
                <field name="name"/>
                <field name="request_date"/>
                <field name="container_id"/>
                <field name="container_type"
                       widget="badge"
                       decoration-info="container_type=='project'"
                       decoration-warning="container_type=='expense_head'"/>
                <field name="amount"/>
                <field name="remaining_billable"/>
                <field name="currency_id" invisible="1"/>
                <field name="requested_by"/>
                <field name="required_date"/>
                <field name="state"
                       widget="badge"
                       decoration-success="state=='approved'"
                       decoration-warning="state in ('submitted','gm_approved')"
                       decoration-danger="state in ('rejected','cancelled')"
                       decoration-muted="state=='closed'"
                       decoration-info="state=='draft'"/>
            </tree>
        </field>
    </record>

    <record id="view_fund_requisition_form" model="ir.ui.view">
        <field name="name">nn.fund.requisition.form</field>
        <field name="model">nn.fund.requisition</field>
        <field name="arch" type="xml">
            <form string="Fund Requisition">
                <header>
                    <button name="action_submit"
                            string="Submit"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_gm_approve"
                            string="GM Approve"
                            type="object"
                            class="btn-primary"
                            groups="nn_fund_management.group_gm_approver"
                            invisible="state != 'submitted'"/>
                    <button name="action_md_approve"
                            string="MD Approve"
                            type="object"
                            class="btn-primary"
                            groups="nn_fund_management.group_md_approver"
                            invisible="state != 'gm_approved'"/>
                    <button name="action_reject"
                            string="Reject"
                            type="object"
                            class="btn-danger"
                            groups="nn_fund_management.group_gm_approver"
                            invisible="state not in ('submitted','gm_approved')"/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            invisible="state in ('approved','rejected','cancelled','closed')"/>
                    <button name="action_close"
                            string="Close Requisition"
                            type="object"
                            class="btn-warning"
                            groups="nn_fund_management.group_finance_user"
                            invisible="state != 'approved'"/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,submitted,gm_approved,approved,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Request Details">
                            <field name="container_id"
                                   readonly="state != 'draft'"/>
                            <field name="container_type"
                                   readonly="1"/>
                            <field name="amount"
                                   readonly="state != 'draft'"/>
                            <field name="currency_id"
                                   invisible="1"/>
                        </group>
                        <group string="Other Info">
                            <field name="request_date"
                                   readonly="state != 'draft'"/>
                            <field name="required_date"
                                   readonly="state != 'draft'"/>
                            <field name="requested_by"
                                   readonly="1"/>
                            <field name="company_id"
                                   readonly="1"/>
                        </group>
                    </group>

                    <group string="Bill Summary"
                           invisible="state not in ('approved','closed')">
                        <group>
                            <field name="amount"
                                   string="Approved Amount"
                                   readonly="1"/>
                            <field name="total_billed"
                                   readonly="1"/>
                        </group>
                        <group>
                            <field name="remaining_billable"
                                   readonly="1"/>
                        </group>
                    </group>

                    <group string="Purpose">
                        <field name="purpose"
                               nolabel="1"
                               readonly="state != 'draft'"/>
                    </group>
                    <group string="Attachments">
                        <field name="attachment_ids"
                               widget="many2many_binary"
                               nolabel="1"/>
                    </group>

                    <notebook>
                        <page string="Bills"
                              invisible="state not in ('approved','closed')">
                            <field name="bill_ids">
                                <tree editable="bottom"
                                      decoration-success="state=='posted'"
                                      decoration-danger="state=='cancelled'">
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="amount"
                                           sum="Total"/>
                                    <field name="state"
                                           widget="badge"
                                           decoration-success="state=='posted'"
                                           decoration-warning="state=='draft'"
                                           decoration-danger="state=='cancelled'"/>
                                    <button name="action_post"
                                            string="Post"
                                            type="object"
                                            class="btn-success"
                                            groups="nn_fund_management.group_finance_user"
                                            invisible="state != 'draft'"
                                            icon="fa-check"/>
                                    <button name="action_cancel"
                                            string="Cancel Bill"
                                            type="object"
                                            class="btn-danger"
                                            groups="nn_fund_management.group_finance_user"
                                            invisible="state != 'draft'"
                                            icon="fa-times"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Approval History">
                            <field name="approval_log_ids"
                                   readonly="1">
                                <tree>
                                    <field name="date"/>
                                    <field name="approver_id"/>
                                    <field name="level"/>
                                    <field name="action"
                                           widget="badge"
                                           decoration-success="action=='approved'"
                                           decoration-danger="action=='rejected'"/>
                                    <field name="comment"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>

                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_fund_requisition" model="ir.actions.act_window">
        <field name="name">Fund Requisitions</field>
        <field name="res_model">nn.fund.requisition</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem
        id="menu_fund_requisition"
        name="Requisitions"
        parent="menu_fund_management_root"
        action="action_fund_requisition"
        sequence="40"/>

</odoo>
