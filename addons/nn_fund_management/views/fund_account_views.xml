<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fund_account_list" model="ir.ui.view">
        <field name="name">fund.account.list</field>
        <field name="model">nn.fund.account</field>
        <field name="arch" type="xml">
            <tree>
                <field name="code"/>
                <field name="name"/>
                <field name="account_type"
                       widget="badge"
                       decoration-info="account_type=='bank'"
                       decoration-success="account_type=='cash'"
                       decoration-warning="account_type=='other'"/>
                <field name="total_received"/>
                <field name="amount_on_hold"/>
                <field name="total_assigned"/>
                <field name="available_unassigned_balance"/>
                <field name="currency_id" invisible="1"/>
                <field name="company_id"/>
                <field name="active" invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="view_fund_account_form" model="ir.ui.view">
        <field name="name">nn.fund.account.form</field>
        <field name="model">nn.fund.account</field>
        <field name="arch" type="xml">
            <form string="Fund Account">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Account Info">
                            <field name="code"/>
                            <field name="account_type"/>
                            <field name="currency_id"/>
                            <field name="company_id"/>
                            <field name="active"/>
                        </group>
                        <group string="Description">
                            <field name="description" nolabel="1"/>
                        </group>
                    </group>

                    <group string="Balance Summary">
                        <group>
                            <field name="total_received"
                                   readonly="1"/>
                            <field name="amount_on_hold"
                                   readonly="1"/>
                        </group>
                        <group>
                            <field name="total_assigned"
                                   readonly="1"/>
                            <field name="available_unassigned_balance"
                                   readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Incoming Funds">
                            <field name="incoming_fund_ids"
                                   readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="amount"/>
                                    <field name="transaction_ref"/>
                                    <field name="sender"/>
                                    <field name="state"
                                           widget="badge"
                                           decoration-success="state=='confirmed'"
                                           decoration-warning="state=='draft'"
                                           decoration-danger="state=='cancelled'"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>

                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_fund_account" model="ir.actions.act_window">
        <field name="name">Fund Accounts</field>
        <field name="res_model">nn.fund.account</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem
        id="menu_fund_management_root"
        name="Fund Management"
        sequence="50"/>

    <menuitem
        id="menu_fund_account"
        name="Fund Accounts"
        parent="menu_fund_management_root"
        action="action_fund_account"
        sequence="10"/>

</odoo>