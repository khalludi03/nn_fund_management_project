<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="module_category_fund_management"
                model="ir.module.category">
            <field name="name">Fund Management</field>
            <field name="description">
                NN Fund Management Module Groups
            </field>
            <field name="sequence">100</field>
        </record>

        <record id="group_fund_user" model="res.groups">
            <field name="name">Fund User</field>
            <field name="category_id"
                   ref="module_category_fund_management"/>
            <field name="comment">
                Can create and view fund requests.
            </field>
        </record>

        <record id="group_finance_user" model="res.groups">
            <field name="name">Finance User</field>
            <field name="category_id"
                   ref="module_category_fund_management"/>
            <field name="implied_ids"
                   eval="[(4, ref('group_fund_user'))]"/>
            <field name="comment">
                Can confirm incoming funds and view all records.
            </field>
        </record>

        <record id="group_gm_approver" model="res.groups">
            <field name="name">GM Approver</field>
            <field name="category_id"
                   ref="module_category_fund_management"/>
            <field name="implied_ids"
                   eval="[(4, ref('group_fund_user'))]"/>
            <field name="comment">
                Can approve or reject at GM level.
            </field>
        </record>

        <record id="group_md_approver" model="res.groups">
            <field name="name">MD Approver</field>
            <field name="category_id"
                   ref="module_category_fund_management"/>
            <field name="implied_ids"
                   eval="[(4, ref('group_gm_approver'))]"/>
            <field name="comment">
                Can approve or reject at MD level.
            </field>
        </record>

        <record id="group_fund_admin" model="res.groups">
            <field name="name">Fund Administrator</field>
            <field name="category_id"
                   ref="module_category_fund_management"/>
            <field name="implied_ids"
                   eval="[
                       (4, ref('group_finance_user')),
                       (4, ref('group_md_approver')),
                   ]"/>
            <field name="comment">
                Full access. Can configure, cancel and delete.
            </field>
        </record>

    </data>
</odoo>
